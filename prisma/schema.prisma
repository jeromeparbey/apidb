datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// rôles utilisateur
enum Role {
  USER
  ADMIN
}

// statut OTP
enum Status {
  PENDING
  USED
  EXPIRED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String

  role      Role     @default(USER)

  // 2FA
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String? // secret pour TOTP (Google Authenticator)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  otps           Otp[]
  resetPasswords ResetPassword[]
  activityLogs   ActivityLog[]
}

model Otp {
  id        String   @id @default(uuid())
  code      String
  status    Status   @default(PENDING)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model ResetPassword {
  id        String   @id @default(uuid())
  token     String
  status    Status   @default(PENDING)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  meta      Json?

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
